# Groq API Key for the free transcription tier (server-side)
# Get your key at https://console.groq.com
# This is used by the API proxy route — never exposed to the client.
GROQ_API_KEY=gsk_your_groq_api_key_here

# The user-facing Groq API URL (public, no need to change)
# NEXT_PUBLIC_GROQ_API_URL=https://api.groq.com/openai/v1/audio/transcriptions
